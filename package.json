    "@typescript-eslint/parser": "^8.58.2",
    "eslint": "^8",
    "eslint-config-next": "^16.2.4",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "lint-staged": "^16.4.0",
    "postcss": "^8",
    "prettier": "^3.8.3",
