# ─── Google Sheets API ───────────────────────────────────────────────────────
# Paste the entire contents of your Service Account JSON key here as a single line.
# In the JSON file, replace all newlines with \n so it fits on one line.
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"wealthiq@...iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# The ID of your Google Sheet (found in the URL: https://docs.google.com/spreadsheets/d/SHEET_ID/edit)
SHEET_ID=your-google-sheet-id-here

# A long random string used to hash the user PIN (generate with: openssl rand -base64 32)
PIN_HASH_SECRET=replace-with-a-long-random-string
